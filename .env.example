# ── Ambiente ──────────────────────────────────────────────────────────────────
# "dev" ignora validações obrigatórias; qualquer outro valor = produção
ENV=dev

# ── Banco de dados ────────────────────────────────────────────────────────────
# Dev:       sqlite:///./mundo_invest.db
# Produção:  postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./mundo_invest.db

# Cria tabelas automaticamente — apenas dev/demo; em produção use Alembic
AUTO_CREATE_TABLES=true

# Ativa logs SQL do SQLAlchemy — apenas dev
DB_ECHO=false

# ── Pipefy ────────────────────────────────────────────────────────────────────
# Obrigatório em produção (ENV != dev)
PIPEFY_TOKEN=seu_token_aqui
PIPEFY_PIPE_ID=302428309

# ── Segurança ─────────────────────────────────────────────────────────────────
# Secret para validar assinatura HMAC dos webhooks (obrigatório em produção)
WEBHOOK_SECRET=seu_webhook_secret_aqui

# Token para endpoints /admin/* (obrigatório em produção)
ADMIN_TOKEN=seu_admin_token_aqui
